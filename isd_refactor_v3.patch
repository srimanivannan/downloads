+        email.setEmail("test@mc.com");
+        email.setHashedEmail("hashedEmail");
+        email.setMaskedEmail("t***@mc.com");
+        email.setPreferred(true);
+
+        Mobile m = new Mobile();
+        m.setCountryCode("91");
+        m.setPhoneNumber("1234567890");
+        m.setHashedCountryCodeWithPhoneNumber("hashedMobile");
