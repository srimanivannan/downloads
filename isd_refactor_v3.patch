+                "test@mc.com",
+                "client",
+                Collections.singletonList(c),
+                c,
+                otp,
+                false,
+                feature
+        );
+
+        PreferredChannelResolution res = engine().resolve(ctx, null);
+        assertEquals(AuthenticationChannel.SMS.name(), res.channels().getPreferredChannel());
+        assertEquals("C2P_NewUser", res.channelRule());
+    }
+}
